{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserList",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "integer"
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "age": {
        "type": "integer",
        "minimum": 0
      },
      "gender": {
        "type": "string",
        "enum": ["male", "female", "other"]
      }
    },
    "required": ["id", "name", "age", "gender"],
    "additionalProperties": false
  }
}